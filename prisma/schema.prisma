generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String   @id @default(cuid())

  title         String
  url           String   @unique

  description   String   @default("")

  imageUrl      String?
  aiImageUrl    String?

  source        String   @default("")
  author        String?

  publishedAt   DateTime

  category      String   @default("ai")

  tags          String   @default("[]")

  content       String?

  summary       String?

  keyPoints     String   @default("[]")


  readTimeMin   Int      @default(3)

  sentiment     String   @default("neutral")

  scrapedAt     DateTime?

  summarizedAt  DateTime?

  // ─────────────────────────────
  // TRENDING + AUTHORIZATION
  // ─────────────────────────────

  isTrending            Boolean @default(false)

  // JSON string: Gemini platform-wise trending metrics
  trendSignals          String  @default("{}")

  // verified from original source?
  authorized            Boolean @default(false)

  // OpenAI / Google / Microsoft etc.
  officialSourceName    String?

  // https://openai.com/blog
  officialSourceUrl     String?

  // Gemini AI auth verification fields
  authConfidence        Float?
  authCheckedAt         DateTime?
  authFlags             String  @default("[]")
  authReasoning         String?

  createdAt             DateTime @default(now())

  updatedAt             DateTime @updatedAt

  saved                 SavedArticle[]
  regeneration          ArticleRegeneration?

  @@index([category])

  @@index([publishedAt])


  @@index([isTrending])

  @@index([authorized])
}

model SavedArticle {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ScrapeJob {
  id        String   @id @default(cuid())
  url       String
  status    String   @default("pending") // pending, running, done, failed
  result    String?  // JSON result stored as string
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model RssCategory {
  id         String      @id @default(cuid())
  name       String      @unique
  label      String
  emoji      String
  color      String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  rssSources RssSource[]
}

model RssSource {
  id          String      @id @default(cuid())
  categoryId  String
  category    RssCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  url         String
  authority   Float       @default(0.8)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([categoryId, url])
}

model ArticleRegeneration {
  id        String   @id @default(cuid())
  articleId String   @unique
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
